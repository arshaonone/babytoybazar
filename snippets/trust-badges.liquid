{% comment %}
  Trust Badges Snippet
  Usage: {% render 'trust-badges' %}
{% endcomment %}

<div class="trust-badges" aria-label="Trust indicators">
  <div class="trust-badge" aria-label="Secure checkout">
    <div class="trust-badge__icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <polyline points="9 12 11 14 15 10"/>
      </svg>
    </div>
    <div class="trust-badge__text">
      <span class="trust-badge__title">100% Secure</span>
      <span class="trust-badge__sub">SSL Encrypted</span>
    </div>
  </div>

  <div class="trust-badge" aria-label="Free shipping">
    <div class="trust-badge__icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="1" y="3" width="15" height="13"/>
        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
        <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
    </div>
    <div class="trust-badge__text">
      <span class="trust-badge__title">Free Shipping</span>
      <span class="trust-badge__sub">Orders over $50</span>
    </div>
  </div>

  <div class="trust-badge" aria-label="Easy returns">
    <div class="trust-badge__icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="1 4 1 10 7 10"/>
        <path d="M3.51 15a9 9 0 1 0 .49-3.4"/>
      </svg>
    </div>
    <div class="trust-badge__text">
      <span class="trust-badge__title">Easy Returns</span>
      <span class="trust-badge__sub">30-Day Policy</span>
    </div>
  </div>

  <div class="trust-badge" aria-label="Safe for kids">
    <div class="trust-badge__icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </div>
    <div class="trust-badge__text">
      <span class="trust-badge__title">Kid Safe</span>
      <span class="trust-badge__sub">Certified Toys</span>
    </div>
  </div>

  <div class="trust-badge" aria-label="24/7 support">
    <div class="trust-badge__icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
      </svg>
    </div>
    <div class="trust-badge__text">
      <span class="trust-badge__title">24/7 Support</span>
      <span class="trust-badge__sub">Always Here</span>
    </div>
  </div>
</div>
