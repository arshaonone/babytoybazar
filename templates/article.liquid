<article class="article-page">
  <div class="container" style="max-width:860px">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" style="margin-bottom:1.5rem;font-size:0.85rem;color:var(--color-text-light)">
      <a href="{{ blog.url }}" style="color:var(--color-text-light)">{{ blog.title }}</a>
      <span style="margin:0 0.5rem" aria-hidden="true">/</span>
      <span aria-current="page">{{ article.title }}</span>
    </nav>

    <!-- Article header -->
    <header style="margin-bottom:2.5rem">
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem">
        {% for tag in article.tags %}
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}"
             style="background:var(--color-primary-light);color:var(--color-accent);padding:0.25rem 0.75rem;border-radius:50px;font-size:0.78rem;font-weight:700">
            {{ tag }}
          </a>
        {% endfor %}
      </div>
      <h1 style="font-size:clamp(1.8rem,4vw,2.8rem);line-height:1.2;margin-bottom:1rem">{{ article.title }}</h1>
      <div style="display:flex;align-items:center;gap:1rem;color:var(--color-text-light);font-size:0.85rem;flex-wrap:wrap">
        <span style="display:flex;align-items:center;gap:0.4rem">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          {{ article.author }}
        </span>
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" style="display:flex;align-items:center;gap:0.4rem">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {{ article.published_at | date: '%B %d, %Y' }}
        </time>
      </div>
    </header>

    <!-- Featured image -->
    {% if article.image %}
      <figure style="margin-bottom:2.5rem;border-radius:var(--radius-xl);overflow:hidden">
        <img src="{{ article.image | image_url: width: 860 }}"
             srcset="{{ article.image | image_url: width: 400 }} 400w, {{ article.image | image_url: width: 860 }} 860w"
             sizes="(max-width:900px) 100vw, 860px"
             alt="{{ article.image.alt | default: article.title | escape }}"
             width="860"
             loading="eager"
             style="width:100%;height:auto">
      </figure>
    {% endif %}

    <!-- Article body -->
    <div style="font-size:1rem;line-height:1.9;color:var(--color-text-secondary);margin-bottom:3rem">
      {{ article.content }}
    </div>

    <!-- Tags -->
    {% if article.tags.size > 0 %}
      <div style="padding:1.5rem 0;border-top:1px solid var(--color-border-light);border-bottom:1px solid var(--color-border-light);margin-bottom:3rem">
        <span style="font-weight:700;font-size:0.9rem;margin-right:0.75rem">Tags:</span>
        {% for tag in article.tags %}
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}"
             style="background:var(--color-bg);color:var(--color-text-secondary);padding:0.3rem 0.9rem;border-radius:50px;font-size:0.82rem;font-weight:600;margin:0.2rem;display:inline-block;border:1px solid var(--color-border)">
            {{ tag }}
          </a>
        {% endfor %}
      </div>
    {% endif %}

    <!-- Prev/Next navigation -->
    <nav style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:3rem" aria-label="Article navigation">
      {% if blog.previous_article %}
        <a href="{{ blog.previous_article.url }}" style="background:var(--color-bg);padding:1.25rem;border-radius:var(--radius-lg);border:1px solid var(--color-border);display:flex;flex-direction:column;gap:0.4rem">
          <span style="font-size:0.75rem;color:var(--color-text-light);font-weight:700;text-transform:uppercase;letter-spacing:0.05em">← Previous</span>
          <span style="font-weight:700;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">{{ blog.previous_article.title }}</span>
        </a>
      {% else %}<div></div>{% endif %}

      {% if blog.next_article %}
        <a href="{{ blog.next_article.url }}" style="background:var(--color-bg);padding:1.25rem;border-radius:var(--radius-lg);border:1px solid var(--color-border);display:flex;flex-direction:column;gap:0.4rem;text-align:right">
          <span style="font-size:0.75rem;color:var(--color-text-light);font-weight:700;text-transform:uppercase;letter-spacing:0.05em">Next →</span>
          <span style="font-weight:700;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">{{ blog.next_article.title }}</span>
        </a>
      {% else %}<div></div>{% endif %}
    </nav>

    <!-- Comments -->
    {% if blog.comments_enabled? %}
      <section aria-label="Comments" style="margin-bottom:3rem">
        <h3 style="margin-bottom:1.5rem">{{ article.comments_count }} Comment{{ article.comments_count | pluralize: '', 's' }}</h3>
        {% if article.comments.size > 0 %}
          {% for comment in article.comments %}
            <div style="background:var(--color-bg);border-radius:var(--radius-md);padding:1.5rem;margin-bottom:1rem;border-left:3px solid var(--color-primary)">
              <div style="display:flex;justify-content:space-between;margin-bottom:0.75rem">
                <strong>{{ comment.author }}</strong>
                <time datetime="{{ comment.created_at | date: '%Y-%m-%d' }}" style="font-size:0.82rem;color:var(--color-text-light)">{{ comment.created_at | date: '%B %d, %Y' }}</time>
              </div>
              <p>{{ comment.content }}</p>
            </div>
          {% endfor %}
        {% endif %}

        <!-- Comment form -->
        {% form 'new_comment', article %}
          <h4 style="margin-bottom:1.25rem;margin-top:2rem">Leave a Comment</h4>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
            <div>
              <label for="CommentAuthor" style="font-size:0.85rem;font-weight:700;display:block;margin-bottom:0.4rem">Name *</label>
              <input type="text" name="comment[author]" id="CommentAuthor" required
                     style="width:100%;padding:0.75rem;border:1px solid var(--color-border);border-radius:var(--radius-md);font-size:0.9rem;outline:none">
            </div>
            <div>
              <label for="CommentEmail" style="font-size:0.85rem;font-weight:700;display:block;margin-bottom:0.4rem">Email *</label>
              <input type="email" name="comment[email]" id="CommentEmail" required
                     style="width:100%;padding:0.75rem;border:1px solid var(--color-border);border-radius:var(--radius-md);font-size:0.9rem;outline:none">
            </div>
          </div>
          <div style="margin-bottom:1rem">
            <label for="CommentBody" style="font-size:0.85rem;font-weight:700;display:block;margin-bottom:0.4rem">Comment *</label>
            <textarea name="comment[body]" id="CommentBody" rows="5" required
                      style="width:100%;padding:0.75rem;border:1px solid var(--color-border);border-radius:var(--radius-md);font-size:0.9rem;resize:vertical;outline:none;font-family:var(--font-primary)"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Post Comment</button>
        {% endform %}
      </section>
    {% endif %}

  </div>
</article>
