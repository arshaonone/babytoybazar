<div class="cart-page">
  <div class="container">
    <h1>{{ 'cart.title' | t }}</h1>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div class="cart-page__grid">

          <!-- Cart items table -->
          <div>
            <table class="cart-table" aria-label="Shopping cart">
              <thead>
                <tr>
                  <th scope="col">Product</th>
                  <th scope="col">Price</th>
                  <th scope="col">Quantity</th>
                  <th scope="col">Total</th>
                  <th scope="col"><span class="visually-hidden">Remove</span></th>
                </tr>
              </thead>
              <tbody>
                {% for item in cart.items %}
                  <tr class="cart-item">
                    <td>
                      <div class="cart-product">
                        <a href="{{ item.url }}" aria-label="{{ item.title }}">
                          {% if item.image %}
                            <img src="{{ item.image | image_url: width: 144 }}"
                                 alt="{{ item.title | escape }}"
                                 width="72" height="72"
                                 loading="lazy">
                          {% endif %}
                        </a>
                        <div>
                          <a href="{{ item.url }}" style="font-weight:700;color:var(--color-text)">{{ item.product.title }}</a>
                          {% unless item.product.has_only_default_variant %}
                            <p style="font-size:0.82rem;color:var(--color-text-light);margin-top:0.2rem">{{ item.variant.title }}</p>
                          {% endunless %}
                        </div>
                      </div>
                    </td>
                    <td><span style="font-weight:700">{{ item.price | money }}</span></td>
                    <td>
                      <div class="cart-qty" data-key="{{ item.key }}" style="display:inline-flex">
                        <button type="button" class="cart-qty__btn cart-qty-minus" data-key="{{ item.key }}" aria-label="Decrease quantity">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                        </button>
                        <span class="cart-qty__num">{{ item.quantity }}</span>
                        <button type="button" class="cart-qty__btn cart-qty-plus" data-key="{{ item.key }}" aria-label="Increase quantity">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                        </button>
                      </div>
                    </td>
                    <td><strong>{{ item.line_price | money }}</strong></td>
                    <td>
                      <a href="{{ item.url_to_remove }}" class="cart-item__del" aria-label="Remove {{ item.title }}">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6m3 0V4a1 1 0 011-1h4a1 1 0 011 1v2"/>
                        </svg>
                      </a>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>

            <!-- Cart note -->
            <div style="margin-top:2rem">
              <label for="CartNote" style="font-weight:700;font-size:0.9rem;display:block;margin-bottom:0.5rem">Order Note (optional)</label>
              <textarea name="note" id="CartNote" rows="3"
                        style="width:100%;border:1px solid var(--color-border);border-radius:var(--radius-md);padding:0.75rem;font-family:var(--font-primary);font-size:0.9rem;resize:vertical;outline:none"
                        placeholder="Special instructions for your order...">{{ cart.note }}</textarea>
            </div>

            <div style="display:flex;gap:1rem;margin-top:1.5rem;flex-wrap:wrap">
              <a href="{{ routes.collections_url }}/all" class="btn btn-outline">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                Continue Shopping
              </a>
              <button type="submit" name="update" class="btn btn-outline" aria-label="Update cart">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.36"/></svg>
                Update Cart
              </button>
            </div>
          </div>

          <!-- Order summary -->
          <div class="cart-summary-box">
            <h3>Order Summary</h3>
            <div class="summary-row"><span>Subtotal</span><span>{{ cart.total_price | money }}</span></div>
            <div class="summary-row"><span>Shipping</span><span style="color:var(--color-success);font-weight:700">Calculated at checkout</span></div>
            {% if cart.total_discount > 0 %}
              <div class="summary-row" style="color:var(--color-badge-sale)">
                <span>Discounts</span><span>-{{ cart.total_discount | money }}</span>
              </div>
            {% endif %}
            <div class="summary-row"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
            <p style="font-size:0.78rem;color:var(--color-text-light);margin-bottom:1.25rem">Taxes and shipping calculated at checkout</p>
            <button type="submit" name="checkout" class="btn btn-primary btn-block btn-lg" aria-label="Proceed to checkout">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              Checkout Now
            </button>
            <!-- Trust badges -->
            <div style="display:flex;justify-content:center;gap:1rem;margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid var(--color-border-light)">
              <div style="display:flex;align-items:center;gap:0.3rem;font-size:0.72rem;color:var(--color-text-light)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                Secure Checkout
              </div>
              <div style="display:flex;align-items:center;gap:0.3rem;font-size:0.72rem;color:var(--color-text-light)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.36"/></svg>
                Free Returns
              </div>
            </div>
          </div>

        </div>
      </form>

    {% else %}
      <div style="text-align:center;padding:5rem 0">
        <div style="font-size:5rem;margin-bottom:1.5rem" aria-hidden="true">🛒</div>
        <h2>{{ 'cart.empty' | t }}</h2>
        <p style="color:var(--color-text-secondary);margin-top:0.5rem;margin-bottom:2rem">Add some amazing toys to your cart!</p>
        <a href="{{ routes.collections_url }}/all" class="btn btn-primary btn-lg">Start Shopping</a>
      </div>
    {% endif %}

  </div>
</div>
