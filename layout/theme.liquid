<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#FFD700">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script>document.documentElement.className = document.documentElement.className.replace('no-js','js');</script>
    <style>
      /* Scroll Progress Bar */
      .scroll-progress-wrap{position:fixed;top:0;left:0;right:0;height:3px;z-index:9999;background:transparent;}
      .scroll-progress{height:100%;width:0;background:linear-gradient(90deg,#FFD700,#FF8C00);transition:width 0.1s linear;}
    </style>
    <script>
      window.BTBConfig = {
        routes: {
          cart_add: '{{ routes.cart_add_url }}',
          cart_get: '{{ routes.cart_url }}.js',
          cart_update: '{{ routes.cart_update_url }}',
          cart_change: '{{ routes.cart_change_url }}',
          search: '{{ routes.search_url }}'
        },
        money_format: {{ shop.money_format | json }},
        currency: {{ shop.currency | json }},
        cart_item_count: {{ cart.item_count }},
        shop_name: {{ shop.name | json }},
        shop_url: {{ shop.url | json }},
        locale: {{ request.locale.iso_code | json }}
      };
    </script>
  </head>

  <body class="template-{{ template.name | handle }}{% if customer %} customer-logged-in{% endif %}">

    <!-- Scroll Progress Bar -->
    <div class="scroll-progress-wrap" aria-hidden="true"><div class="scroll-progress" id="ScrollProgress"></div></div>

    <a class="skip-to-content" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

    {% section 'announcement-bar' %}
    {% section 'header' %}

    <!-- Trust Badges Strip -->
    {% render 'trust-badges' %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    <!-- Recently Viewed Products -->
    {% section 'recently-viewed' %}

    {% section 'footer' %}

    <!-- ===================== CART DRAWER ===================== -->
    <div class="cart-drawer" id="CartDrawer" aria-hidden="true">
      <div class="cart-drawer__overlay" id="CartDrawerOverlay"></div>
      <div class="cart-drawer__panel" role="dialog" aria-modal="true" aria-label="Shopping Cart">

        <div class="cart-drawer__header">
          <div class="cart-drawer__title">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 001.99 1.61h9.72a2 2 0 001.99-1.61L23 6H6"/>
            </svg>
            <span>Shopping Cart</span>
            <span class="cart-badge-inline" id="CartDrawerCount">{{ cart.item_count }}</span>
          </div>
          <button class="icon-btn" id="CartDrawerClose" aria-label="{{ 'accessibility.close_modal' | t }}">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <div class="cart-drawer__body" id="CartDrawerBody">
          {% if cart.item_count == 0 %}
            <div class="cart-empty">
              <div class="cart-empty__icon">
                <svg width="72" height="72" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                  <path d="M1 1h4l2.68 13.39a2 2 0 001.99 1.61h9.72a2 2 0 001.99-1.61L23 6H6"/>
                </svg>
              </div>
              <h4>Your cart is empty!</h4>
              <p>Add some amazing toys to get started</p>
              <a href="/collections/all" class="btn btn-primary" id="CartEmptyShopLink">Start Shopping</a>
            </div>
          {% else %}
            <div class="cart-items-list" id="CartItemsList">
              {% for item in cart.items %}
                <div class="cart-item" data-key="{{ item.key }}">
                  <a class="cart-item__img-wrap" href="{{ item.url }}">
                    {% if item.image %}
                      <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.title | escape }}" width="80" height="80" loading="lazy">
                    {% else %}
                      <div class="cart-item__img-placeholder">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                      </div>
                    {% endif %}
                  </a>
                  <div class="cart-item__info">
                    <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title }}</a>
                    {% unless item.product.has_only_default_variant %}
                      <p class="cart-item__variant">{{ item.variant.title }}</p>
                    {% endunless %}
                    <div class="cart-item__meta">
                      <div class="cart-qty" data-key="{{ item.key }}">
                        <button class="cart-qty__btn cart-qty-minus" data-key="{{ item.key }}" aria-label="Decrease">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/></svg>
                        </button>
                        <span class="cart-qty__num">{{ item.quantity }}</span>
                        <button class="cart-qty__btn cart-qty-plus" data-key="{{ item.key }}" aria-label="Increase">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
                        </button>
                      </div>
                      <span class="cart-item__price">{{ item.line_price | money }}</span>
                    </div>
                  </div>
                  <button class="cart-item__del" data-key="{{ item.key }}" aria-label="Remove">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6m3 0V4a1 1 0 011-1h4a1 1 0 011 1v2"/>
                    </svg>
                  </button>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        {% if cart.item_count > 0 %}
          <div class="cart-drawer__footer">
            <div class="cart-free-ship">
              {% assign threshold_cents = 5000 %}
              {% assign remaining_cents = threshold_cents | minus: cart.total_price %}
              {% if remaining_cents > 0 %}
                {% assign remaining_dollars = remaining_cents | money %}
                <p>Add <strong>{{ remaining_dollars }}</strong> more for <strong>FREE shipping!</strong> 🚚</p>
                {% assign pct = cart.total_price | times: 100 | divided_by: threshold_cents %}
                <div class="ship-bar"><div class="ship-bar__fill" style="width:{{ pct | at_most: 100 }}%"></div></div>
              {% else %}
                <p class="ship-unlocked">🎉 You've unlocked <strong>FREE shipping!</strong></p>
              {% endif %}
            </div>
            <div class="cart-subtotal-row">
              <span>Subtotal</span>
              <strong class="cart-subtotal-price" id="CartSubtotal">{{ cart.total_price | money }}</strong>
            </div>
            <p class="cart-tax-note">Taxes and shipping calculated at checkout</p>
            <a href="/checkout" class="btn btn-primary btn-block">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              Checkout Now
            </a>
            <a href="/cart" class="btn btn-outline btn-block" style="margin-top:0.75rem">View Full Cart</a>
          </div>
        {% endif %}

      </div>
    </div>

    <!-- ===================== SEARCH OVERLAY ===================== -->
    <div class="search-overlay" id="SearchOverlay" aria-hidden="true">
      <div class="search-overlay__inner">
        <form action="{{ routes.search_url }}" method="get" role="search" class="search-overlay__form">
          <input type="hidden" name="type" value="product">
          <div class="search-overlay__field">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="search" name="q" placeholder="{{ 'general.search.placeholder' | t }}" class="search-overlay__input" autocomplete="off" id="SearchOverlayInput">
            <button type="submit" class="search-overlay__submit">Search</button>
          </div>
        </form>
        <button class="search-overlay__close icon-btn" id="SearchOverlayClose" aria-label="Close search">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
    </div>

    <!-- ===================== BACK TO TOP ===================== -->
    <button class="back-to-top" aria-label="Back to top" id="BackToTop" title="Back to top">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>
    </button>

    <!-- ===================== TOAST NOTIFICATION ===================== -->
    <div class="toast" id="ToastMsg" role="status" aria-live="polite">
      <span class="toast__icon" id="ToastIcon"></span>
      <span class="toast__text" id="ToastText"></span>
    </div>

    <!-- ===================== QUICK VIEW MODAL ===================== -->
    <div class="qv-modal" id="QuickViewModal" aria-hidden="true">
      <div class="qv-modal__overlay" id="QVOverlay"></div>
      <div class="qv-modal__panel" role="dialog" aria-modal="true" aria-label="Quick view">
        <button class="qv-modal__close icon-btn" id="QVClose" aria-label="Close">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
        <div class="qv-modal__body" id="QVBody">
          <div class="qv-loading">
            <div class="spinner"></div>
          </div>
        </div>
      </div>
    </div>

    {{ 'theme.js' | asset_url | script_tag }}
  </body>
</html>
