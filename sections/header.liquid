<header class="site-header" id="SiteHeader" role="banner">

  <!-- ====== TOP HEADER ROW ====== -->
  <div class="site-header__main">

    <!-- Hamburger (mobile) -->
    <button class="mobile-menu-btn" id="MobileMenuBtn" aria-label="{{ 'accessibility.open_menu' | t }}" aria-expanded="false" aria-controls="MobileNav">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    <!-- Logo -->
    <div class="site-logo">
      {%- if settings.logo != blank -%}
        <a href="{{ routes.root_url }}" class="site-logo__text" aria-label="{{ shop.name }} home">
          <img src="{{ settings.logo | image_url: width: settings.logo_width }}"
               alt="{{ shop.name }}"
               width="{{ settings.logo_width }}"
               class="site-logo__img"
               loading="eager">
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="site-logo__text" aria-label="{{ shop.name }} home">
          <div class="site-logo__icon" aria-hidden="true">🧸</div>
          <div class="site-logo__name">
            {{ settings.logo_text | split: ' ' | first }}<span>{{ settings.logo_text | split: ' ' | last }}</span>
          </div>
        </a>
      {%- endif -%}
    </div>

    <!-- Search Bar -->
    <div class="header-search">
      <form action="{{ routes.search_url }}" method="get" role="search" class="header-search__form" aria-label="Site search">
        <input type="hidden" name="type" value="product">
        <input type="search"
               name="q"
               class="header-search__input"
               placeholder="{{ 'general.search.placeholder' | t }}"
               aria-label="{{ 'general.search.placeholder' | t }}"
               value="{{ search.terms | escape }}"
               autocomplete="off">
        <button type="submit" class="header-search__btn" aria-label="{{ 'general.search.submit' | t }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
      </form>
    </div>

    <!-- Header Action Icons -->
    <nav class="header-actions" aria-label="Account and cart navigation">

      <!-- Search (mobile icon) -->
      <button class="header-action" data-open-search aria-label="Open search" id="SearchBtn">
        <span class="header-action__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </span>
        <span class="header-action__label">Search</span>
      </button>

      <!-- Wishlist -->
      <a class="header-action" href="{{ routes.root_url }}pages/wishlist" aria-label="Wishlist" id="WishlistBtn">
        <span class="header-action__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span class="header-action__badge" id="WishlistCount" aria-label="0 items in wishlist" style="display:none">0</span>
        </span>
        <span class="header-action__label">Wishlist</span>
      </a>

      <!-- Compare -->
      <a class="header-action" href="{{ routes.root_url }}pages/compare" aria-label="Compare products">
        <span class="header-action__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
          <span class="header-action__badge" id="CompareCount" aria-label="0 items to compare" style="display:none">0</span>
        </span>
        <span class="header-action__label">Compare</span>
      </a>

      <!-- Cart -->
      <button class="header-action" data-open-cart id="CartBtn" aria-label="Open shopping cart, {{ cart.item_count }} items">
        <span class="header-action__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 001.99 1.61h9.72a2 2 0 001.99-1.61L23 6H6"/>
          </svg>
          <span class="header-action__badge cart-item-count" aria-live="polite">{{ cart.item_count }}</span>
        </span>
        <span class="header-action__label">Cart</span>
      </button>

      <!-- Account -->
      {%- if customer -%}
        <a class="header-action" href="{{ routes.account_url }}" aria-label="My Account">
          <span class="header-action__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </span>
          <span class="header-action__label">Account</span>
        </a>
      {%- else -%}
        <a class="header-action" href="{{ routes.account_login_url }}" aria-label="Sign in">
          <span class="header-action__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </span>
          <span class="header-action__label">Sign In</span>
        </a>
      {%- endif -%}

    </nav>
  </div>

