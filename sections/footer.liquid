<footer class="site-footer" role="contentinfo" aria-label="Site footer">
  <div class="container">

    <!-- Main footer grid -->
    <div class="footer-main">

      <!-- About column -->
      <div class="footer-about footer-col">
        <div class="footer-about__logo">
          <div class="footer-logo-icon" aria-hidden="true">🧸</div>
          <div class="footer-logo-name">
            BabyToy<span>Bazaar</span>
          </div>
        </div>
        <p>Premium toys for happy, curious babies. Safe, certified, and loved by parents worldwide. Cash on Delivery — no card needed!</p>
        <!-- Social icons -->
        <div class="footer-social" aria-label="Social media links">
          {% if settings.footer_facebook != blank %}
            <a href="{{ settings.footer_facebook }}" class="social-btn" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {% endif %}
          {% if settings.footer_instagram != blank %}
            <a href="{{ settings.footer_instagram }}" class="social-btn" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {% endif %}
          {% if settings.footer_youtube != blank %}
            <a href="{{ settings.footer_youtube }}" class="social-btn" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.41 19.1C5.12 19.56 12 19.56 12 19.56s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.34z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="white"/></svg>
            </a>
          {% endif %}
          {% if settings.footer_tiktok != blank %}
            <a href="{{ settings.footer_tiktok }}" class="social-btn" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V9.04a8.16 8.16 0 004.77 1.52V7.12a4.85 4.85 0 01-1-.43z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Quick Links -->
      <nav class="footer-col" aria-label="Quick links">
        <h4>Quick Links</h4>
        <ul class="footer-links">
          <li><a href="{{ routes.root_url }}">🏠 Home</a></li>
          <li><a href="{{ routes.collections_url }}">🪀 All Toys</a></li>
          <li><a href="/collections/baby-toys">🍼 Baby Toys</a></li>
          <li><a href="/collections/educational">📚 Educational</a></li>
          <li><a href="/collections/new-arrivals">✨ New Arrivals</a></li>
          <li><a href="/collections/sale">🏷️ Sale</a></li>
        </ul>
      </nav>

      <!-- Customer Care -->
      <nav class="footer-col" aria-label="Customer care links">
        <h4>Customer Care</h4>
        <ul class="footer-links">
          <li><a href="/pages/faq">❓ FAQ</a></li>
          <li><a href="/pages/shipping-policy">🚚 Shipping Info</a></li>
          <li><a href="/pages/return-policy">↩️ Returns Policy</a></li>
          <li><a href="/pages/size-guide">📏 Size Guide</a></li>
          <li><a href="/pages/track-order">📦 Track My Order</a></li>
          <li><a href="/pages/contact">💬 Contact Us</a></li>
        </ul>
      </nav>

      <!-- Contact -->
      <div class="footer-col">
        <h4>Contact Us</h4>
        <ul class="footer-contact">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:hello@babytoybazaar.com">hello@babytoybazaar.com</a>
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.22H6.6a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91A16 16 0 0 0 13 15l.86-.86a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 20.51 16.92z"/></svg>
            <span>+880 1800-TOYBAZAR</span>
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Mon–Sat, 9am – 7pm (BD Time)</span>
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Dhaka, Bangladesh</span>
          </li>
        </ul>
      </div>

    </div><!-- /.footer-main -->

    <!-- Bottom bar -->
    <div class="footer-bottom-bar">
      <div class="footer-bottom">

        <p class="footer-copyright">
          &copy; {{ 'now' | date: '%Y' }} <strong style="color:rgba(255,255,255,0.7)">BabyToyBazaar.com</strong> &mdash; All rights reserved.
        </p>

        <div class="footer-bottom__right">
          <!-- COD Badge -->
          <div class="cod-badge" aria-label="Cash on Delivery available">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            💵 Cash on Delivery Only
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </div>

          <!-- Safety badge -->
          <div class="footer-safety">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            CE Certified &amp; CPSC Compliant · Safe 0+
          </div>
        </div>

      </div>
    </div>

  </div><!-- /.container -->
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "url",
      "id": "footer_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "footer_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "footer_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "footer_tiktok",
      "label": "TikTok URL"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
