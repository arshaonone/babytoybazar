<section class="hero-slider" id="HeroSlider" aria-label="Hero banner">

  {% for block in section.blocks %}
    {% if block.type == 'slide' %}
      <div class="hero-slide{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>

        <!-- Background -->
        <div class="hero-slide__bg"></div>

        <!-- Decorative floating clouds -->
        <div class="hero-shape hero-cloud cloud-1" aria-hidden="true"></div>
        <div class="hero-shape hero-cloud cloud-2" aria-hidden="true"></div>
        <div class="hero-shape hero-cloud cloud-3" aria-hidden="true"></div>

        <!-- Floating stars -->
        <div class="hero-shape hero-star star-1" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <div class="hero-shape hero-star star-2" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <div class="hero-shape hero-star star-3" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>

        <!-- Floating circles -->
        <div class="hero-shape hero-circle circle-1" aria-hidden="true"></div>
        <div class="hero-shape hero-circle circle-2" aria-hidden="true"></div>
        <div class="hero-shape hero-circle fill circle-3" aria-hidden="true"></div>
        <div class="hero-shape hero-circle fill circle-4" aria-hidden="true"></div>

        <!-- Content -->
        <div class="container" style="position:relative;z-index:2">
          <div class="hero-slide__content">
            {% if block.settings.badge != blank %}
              <div class="hero-badge" aria-label="{{ block.settings.badge }}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {{ block.settings.badge }}
              </div>
            {% endif %}

            <h1 class="hero-title">
              <span>{{ block.settings.title }}</span>
              <span>{{ block.settings.subtitle }}</span>
            </h1>

            {% if block.settings.description != blank %}
              <p class="hero-subtitle">{{ block.settings.description }}</p>
            {% endif %}

            <div class="hero-cta-wrap">
              {% if block.settings.button_text != blank %}
                <a href="{{ block.settings.button_url | default: '/collections/all' }}"
                   class="btn-hero"
                   aria-label="{{ block.settings.button_text }}">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 001.99 1.61h9.72a2 2 0 001.99-1.61L23 6H6"/>
                  </svg>
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
              {% if block.settings.secondary_button_text != blank %}
                <a href="{{ block.settings.secondary_button_url | default: '/collections' }}"
                   class="btn-hero-outline"
                   aria-label="{{ block.settings.secondary_button_text }}">
                  {{ block.settings.secondary_button_text }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              {% endif %}
            </div>
          </div>
        </div>

        <!-- Hero image -->
        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url: width: 600 }}"
               srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 600 }} 600w"
               sizes="(max-width:768px) 0px, 580px"
               alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
               class="hero-slide__image"
               loading="eager"
               width="580">
        {% endif %}

      </div>
    {% endif %}
  {% endfor %}

  <!-- Dot indicators -->
  {% if section.blocks.size > 1 %}
    <div class="slider-dots" role="tablist" aria-label="Slider controls">
      {% for block in section.blocks %}
        {% if block.type == 'slide' %}
          <button class="slider-dot{% if forloop.first %} active{% endif %}"
                  role="tab"
                  aria-selected="{{ forloop.first }}"
                  aria-label="Slide {{ forloop.index }}"
                  data-slide="{{ forloop.index0 }}"></button>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Prev/Next arrows -->
    <button class="slider-arrow prev" id="SliderPrev" aria-label="Previous slide">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="slider-arrow next" id="SliderNext" aria-label="Next slide">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  {% endif %}

</section>

<script>
(function(){
  var slider = document.getElementById('HeroSlider');
  if(!slider) return;
  var slides = slider.querySelectorAll('.hero-slide');
  var dots = slider.querySelectorAll('.slider-dot');
  var prevBtn = document.getElementById('SliderPrev');
  var nextBtn = document.getElementById('SliderNext');
  if(slides.length < 2) return;

  var current = 0;
  var total = slides.length;
  var autoTimer;
  var touchX = 0;

  function show(n){
    n = (n + total) % total;
    slides.forEach(function(s,i){
      s.style.display = i===n ? 'flex' : 'none';
    });
    dots.forEach(function(d,i){
      d.classList.toggle('active', i===n);
      d.setAttribute('aria-selected', i===n ? 'true' : 'false');
    });
    current = n;
  }

  function startAuto(){
    autoTimer = setInterval(function(){ show(current+1); }, {{ section.settings.autoplay_speed | default: 5 }}000);
  }
  function stopAuto(){ clearInterval(autoTimer); }

  show(0);
  startAuto();

  if(prevBtn) prevBtn.addEventListener('click', function(){ stopAuto(); show(current-1); startAuto(); });
  if(nextBtn) nextBtn.addEventListener('click', function(){ stopAuto(); show(current+1); startAuto(); });
  dots.forEach(function(dot,i){ dot.addEventListener('click', function(){ stopAuto(); show(i); startAuto(); }); });
  slider.addEventListener('touchstart', function(e){ touchX = e.changedTouches[0].clientX; }, {passive:true});
  slider.addEventListener('touchend', function(e){
    var dx = e.changedTouches[0].clientX - touchX;
    if(Math.abs(dx) > 50){ stopAuto(); show(current + (dx<0 ? 1 : -1)); startAuto(); }
  }, {passive:true});
  slider.addEventListener('mouseenter', stopAuto);
  slider.addEventListener('mouseleave', startAuto);
})();
</script>

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "class": "hero-slider-section",
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text",
          "default": "New Collection 2024"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title (Line 1)",
          "default": "Create Happiness"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Title (Line 2)",
          "default": "With Toys"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shopping Now"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        },
        {
          "type": "text",
          "id": "secondary_button_text",
          "label": "Secondary Button Text",
          "default": "View Collection"
        },
        {
          "type": "url",
          "id": "secondary_button_url",
          "label": "Secondary Button URL"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay Speed",
      "default": 5
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "badge": "New Collection 2024",
            "title": "Create Happiness",
            "subtitle": "With Toys",
            "button_text": "Shopping Now"
          }
        },
        {
          "type": "slide",
          "settings": {
            "badge": "Up to 80% Off",
            "title": "Best Toys For",
            "subtitle": "Your Little Ones",
            "button_text": "Shop Sale"
          }
        },
        {
          "type": "slide",
          "settings": {
            "badge": "Free Shipping Available",
            "title": "Educational &",
            "subtitle": "Fun Toys",
            "button_text": "Explore Now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
