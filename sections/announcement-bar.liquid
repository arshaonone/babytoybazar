<div class="announcement-bar" role="region" aria-label="Announcement">
  <div class="announcement-bar__inner">

    <div class="announcement-bar__messages">
      {%- for block in section.blocks -%}
        {%- if block.type == 'message' -%}
          <span class="announce-msg">{{ block.settings.text }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="announcement-bar__right">
      {%- if section.settings.show_track_order -%}
        <a href="{{ section.settings.track_order_url | default: '/pages/track-order' }}" style="font-size:0.78rem;font-weight:700;color:#fff;text-decoration:none;opacity:0.9">
          📦 Track Order
        </a>
      {%- endif -%}

      {%- if localization.available_currencies.size > 1 -%}
        <div class="announce-dropdown-wrap">
          <button class="announce-lc-btn" id="AnnCurrBtn" aria-expanded="false" aria-label="Select currency">
            {{ cart.currency.iso_code }}
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="announce-dropdown" id="AnnCurrDrop">
            {%- form 'localization', id: 'AnnCurrencyForm' -%}
              <input type="hidden" name="locale_code" value="{{ request.locale.iso_code }}">
              {%- for currency in localization.available_currencies -%}
                <button type="submit" name="currency_code" value="{{ currency.iso_code }}"
                  class="announce-dropdown__item{% if currency.iso_code == cart.currency.iso_code %} selected{% endif %}">
                  {{ currency.iso_code }} – {{ currency.symbol }}
                </button>
              {%- endfor -%}
            {%- endform -%}
          </div>
        </div>
      {%- endif -%}

      {%- if localization.available_languages.size > 1 -%}
        <div class="announce-dropdown-wrap">
          <button class="announce-lc-btn" id="AnnLangBtn" aria-expanded="false" aria-label="Select language">
            {{ request.locale.iso_code | upcase }}
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="announce-dropdown" id="AnnLangDrop">
            {%- form 'localization', id: 'AnnLangForm' -%}
              <input type="hidden" name="currency_code" value="{{ cart.currency.iso_code }}">
              {%- for language in localization.available_languages -%}
                <button type="submit" name="locale_code" value="{{ language.iso_code }}"
                  class="announce-dropdown__item{% if language.iso_code == request.locale.iso_code %} selected{% endif %}">
                  {{ language.endonym_name }}
                </button>
              {%- endfor -%}
            {%- endform -%}
          </div>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

<script>
(function(){
  function initDropdown(btnId, dropId) {
    var btn = document.getElementById(btnId);
    var drop = document.getElementById(dropId);
    if (!btn || !drop) return;
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var isOpen = drop.classList.contains('open');
      document.querySelectorAll('.announce-dropdown.open').forEach(function(d){ d.classList.remove('open'); });
      document.querySelectorAll('.announce-lc-btn').forEach(function(b){ b.setAttribute('aria-expanded','false'); });
      if (!isOpen) { drop.classList.add('open'); btn.setAttribute('aria-expanded','true'); }
    });
  }
  initDropdown('AnnCurrBtn','AnnCurrDrop');
  initDropdown('AnnLangBtn','AnnLangDrop');
  document.addEventListener('click', function(){
    document.querySelectorAll('.announce-dropdown.open').forEach(function(d){ d.classList.remove('open'); });
    document.querySelectorAll('.announce-lc-btn').forEach(function(b){ b.setAttribute('aria-expanded','false'); });
  });
})();
</script>

{% schema %}
{
  "name": "Announcement bar",
  "class": "announcement-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_track_order",
      "label": "Show Track Order link",
      "default": true
    },
    {
      "type": "url",
      "id": "track_order_url",
      "label": "Track Order URL"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Message",
          "default": "🎁 Free Shipping on orders over $50 🎁"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "text": "🎁 Free Shipping on orders over $50 🎁"
          }
        }
      ]
    }
  ]
}
{% endschema %}
